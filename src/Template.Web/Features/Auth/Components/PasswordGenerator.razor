@page "/password-generator"
@using Template.Client.State
@using Template.Client.Features.Auth.State
@inject Store Store
@implements IDisposable

<PageTitle>Password Generator</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-8" Elevation="3">
        <MudText Typo="Typo.h5" GutterBottom="true">Password Generator</MudText>
        
        <MudTextField Value="@_state.GeneratedPassword" 
                      Label="Generated Password" 
                      Variant="Variant.Outlined" 
                      ReadOnly="true" 
                      Adornment="Adornment.End" 
                      AdornmentIcon="@Icons.Material.Filled.ContentCopy" 
                      OnAdornmentClick="CopyPassword" />
        
        <MudSlider @bind-Value="_length" Min="6" Max="32" Color="Color.Primary">Length: @_length</MudSlider>
        
        <MudCheckBox @bind-Value="_useSpecial" Label="@SpecialLabel" Color="Color.Primary"></MudCheckBox>
        <MudCheckBox @bind-Value="_useNumbers" Label="Numbers (0-9)" Color="Color.Primary"></MudCheckBox>
        
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Secondary" 
                   OnClick="Generate" 
                   Class="mt-4">
            Generate
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    private AuthState _state = new();
    private int _length = 12;
    private bool _useSpecial = true;
    private bool _useNumbers = true;
    private const string SpecialLabel = "Special Characters (!@#$)";

    protected override void OnInitialized()
    {
        _state = Store.GetState<AuthState>();
        // Hidratamos los controles locales desde el estado global si es necesario
        _length = _state.Configuration.Length;
        _useSpecial = _state.Configuration.UseSpecial;
        _useNumbers = _state.Configuration.UseNumbers;

        Store.Subscribe<AuthState>(UpdateState);
    }

    private void UpdateState(AuthState newState)
    {
        _state = newState;
        InvokeAsync(StateHasChanged);
    }

    private void Generate()
    {
        var action = new GeneratePasswordAction(_length, _useSpecial, _useNumbers);
        
        // Disparamos la acción a través del Store.
        // Los Reducers suscritos capturarán esta acción y actualizarán el estado.
        // (Nota: En un patrón Flux completo, esto iría por un Dispatcher centralizado).
        Store.Dispatch(action); 
    }

    private void CopyPassword()
    {
        // Copy logic
    }

    public void Dispose()
    {
        // Limpieza de suscripciones si fuera necesario
    }
}
