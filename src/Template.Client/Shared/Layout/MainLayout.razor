@inherits LayoutComponentBase
@using Template.Client.Features.Auth.Services.Interfaces
@using Template.Client.State
@using Template.Client.Features.Auth.State
@using Template.Client.Features.Auth.Services
@using Template.Client.Theme

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<Template.Client.Shared.Components.CookieConsent />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h5" Class="ml-3 mr-8">BaseCore</MudText>
        
        <!-- Horizontal Navigation -->
        <MudHidden Breakpoint="Breakpoint.MdAndDown" Invert="true">
             <!-- Mobile Menu Placeholder -->
        </MudHidden>

        <MudStack Row="true" Spacing="4" Class="d-none d-md-flex">
            <MudButton Href="/" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Dashboard">Dashboard</MudButton>
            @if (_authState.IsAuthenticated)
            {
                <MudButton Href="/profile" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Person">My profile</MudButton>
            }
        </MudStack>

        <MudSpacer />
        
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.Brightness7 : Icons.Material.Filled.Brightness4)" Color="Color.Inherit" OnClick="@ToggleTheme" Class="mr-2" />
                <AuthorizeView>
                    <Authorized>
                        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" LockScroll="true">
                            <ActivatorContent>
                                <MudButton Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Person" EndIcon="@Icons.Material.Filled.ArrowDropDown">
                                    @context.User.Identity?.Name
                                </MudButton>
                            </ActivatorContent>
                            <ChildContent>
                                <MudMenuItem Href="/profile" Icon="@Icons.Material.Filled.Person">My Profile</MudMenuItem>
                                <MudMenuItem Href="/change-password" Icon="@Icons.Material.Filled.Key">Change Password</MudMenuItem>
                                @if (IsDevelopment)
                                {
                                    <MudMenuItem Href="https://localhost:7197/.well-known/openid-configuration" Target="_blank" Icon="@Icons.Material.Filled.Info">Identity Info</MudMenuItem>
                                }
                                <MudDivider />
                                <MudMenuItem OnClick="LogoutAsync" Icon="@Icons.Material.Filled.Logout">Logout</MudMenuItem>
                            </ChildContent>
                        </MudMenu>
                    </Authorized>
                    <NotAuthorized>
                        <MudMenu Icon="@Icons.Material.Filled.Person" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" LockScroll="true">
                            <MudMenuItem Href="/login" Icon="@Icons.Material.Filled.Login">Login</MudMenuItem>
                            @if (IsDevelopment)
                            {
                                <MudMenuItem Href="https://localhost:7197/.well-known/openid-configuration" Target="_blank" Icon="@Icons.Material.Filled.Info">Identity Info</MudMenuItem>
                            }
                        </MudMenu>
                    </NotAuthorized>
                </AuthorizeView>
    </MudAppBar>
    
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4 pt-16">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
