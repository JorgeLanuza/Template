@page "/"

<PageTitle>Dashboard</PageTitle>

<MudText Typo="Typo.subtitle1" Class="mb-4">Welcome to your BaseCore application.</MudText>

<MudGrid>
    <MudItem xs="12">
        <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="mb-4">
            You are running the <strong>Self-Hosted Identity</strong> version of the template.
        </MudAlert>
    </MudItem>

    <MudItem xs="12" sm="6">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Authentication</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.Security" Color="Color.Primary" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2">
                    Manage your credentials, profile, and security settings directly from this application.
                </MudText>
            </MudCardContent>
             <MudCardActions>
                 <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/login">Login</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>
