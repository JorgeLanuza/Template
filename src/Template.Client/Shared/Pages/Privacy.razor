@page "/privacy"

<PageTitle>Privacy Policy</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudText Typo="Typo.h3" GutterBottom="true">Privacy & Cookie Policy</MudText>
    
    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h5" GutterBottom="true">1. Introduction</MudText>
        <MudText Paragraph="true">
            Welcome to the BaseCore Template application. We are committed to protecting your personal information and your right to privacy.
        </MudText>

        <MudText Typo="Typo.h5" Class="mt-4" GutterBottom="true">2. Cookies</MudText>
        <MudText Paragraph="true">
            We use cookies to enhance your browsing experience, serve personalized content, and analyze our traffic. 
            By clicking "Accept" in our cookie banner, you consent to our use of cookies.
        </MudText>

        <MudText Typo="Typo.h6" Class="mt-2" GutterBottom="true">Essential Cookies</MudText>
        <MudText Paragraph="true">
            These cookies are necessary for the website to function and cannot be switched off in our systems. 
            They are usually only set in response to actions made by you which amount to a request for services, such as logging in or filling in forms.
        </MudText>
    </MudPaper>
</MudContainer>

