@page "/forgot-password"

<PageTitle>Forgot Password</PageTitle>

@using BaseCore.Framework.Security.Identity.Entities
@using Microsoft.AspNetCore.Identity

@inject UserManager<BaseUser> UserManager
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center mud-width-full" Style="height: 70vh;">
    <MudPaper Class="pa-8" Elevation="3" Width="400px">
        <MudStack Spacing="4">
            <MudText Typo="Typo.h5" Align="Align.Center">Recovery</MudText>
            <MudText Typo="Typo.body2" Align="Align.Center">Enter your email and we will send you a reset link.</MudText>
            
            <MudForm @ref="form">
                <MudTextField T="string" Label="Email" @bind-Value="Email" Variant="Variant.Outlined" Required="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
            </MudForm>
            
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true" OnClick="OnForgotPasswordAsync">Send Link</MudButton>
             <MudButton Variant="Variant.Text" Color="Color.Secondary" FullWidth="true" Href="/login">Back to Login</MudButton>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    string? Email;
    MudForm? form;

    private async Task OnForgotPasswordAsync()
    {
        await form!.Validate();
        if (!form.IsValid) return;

        var user = await UserManager.FindByEmailAsync(Email!);
        if (user != null) // && await UserManager.IsEmailConfirmedAsync(user))
        {
            var code = await UserManager.GeneratePasswordResetTokenAsync(user);
            // Mock Email Sending: In production, send this code via email
            // Navigation.NavigateTo($"/Account/ResetPassword?code={code}");
        }

        // Always redirect to confirmation to avoid enumeration
        // Navigation.NavigateTo("/Account/ForgotPasswordConfirmation");
    }
}
