@page "/admin/policies"
@using MudBlazor

<PageTitle>Security Policies</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true" Class="mb-4"><b>Security Policies</b></MudText>
    <MudText Typo="Typo.body1" Class="mb-4" Color="Color.Secondary">Manage password complexity and account locking rules.</MudText>

    @if (_state.IsLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }
    
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6 glass-panel" Color="Color.Transparent" SliderColor="Color.Primary">
        <MudTabPanel Text="Password Policy" Icon="@Icons.Material.Filled.Security">
            <MudForm @ref="passwordForm" @bind-IsValid="@passwordSuccess">
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudCard Elevation="0" Outlined="false" Class="glass-panel">
                            <MudCardHeader>
                                <CardHeaderContent><MudText Typo="Typo.h6">Length Rules</MudText></CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudSlider T="int" @bind-Value="PasswordPolicy.PasswordMinLenght" Min="6" Max="32" Color="Color.Primary" ValueLabel="true">Min Length: @PasswordPolicy.PasswordMinLenght</MudSlider>
                                <MudSlider T="int" @bind-Value="PasswordPolicy.PasswordMaxLenght" Min="12" Max="128" Color="Color.Primary" ValueLabel="true">Max Length: @PasswordPolicy.PasswordMaxLenght</MudSlider>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudCard Elevation="0" Outlined="false" Class="glass-panel">
                            <MudCardHeader>
                                <CardHeaderContent><MudText Typo="Typo.h6">Expiration & Reuse</MudText></CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudSwitch @bind-Value="PasswordPolicy.PasswordExpirationFlag" Color="Color.Primary" Label="Enable Expiration" />
                                @if(PasswordPolicy.PasswordExpirationFlag)
                                {
                                    <MudNumericField @bind-Value="PasswordPolicy.PasswordExpiration" Label="Expiration Days" Variant="Variant.Outlined" Min="1" Max="365" Class="glass-input" />
                                }
                                
                                <MudSwitch @bind-Value="PasswordPolicy.OldPasswordCheckFlag" Color="Color.Primary" Label="Prevent Password Reuse" Class="mt-4" />
                                @if(PasswordPolicy.OldPasswordCheckFlag)
                                {
                                    <MudNumericField @bind-Value="PasswordPolicy.OldPasswordChecked" Label="History Depth (Count)" Variant="Variant.Outlined" Min="1" Max="24" Class="glass-input" />
                                }
                                
                                <MudSwitch @bind-Value="PasswordPolicy.TimeLimitCheckFlag" Color="Color.Primary" Label="Enforce Minimum Age" Class="mt-4" />
                                @if(PasswordPolicy.TimeLimitCheckFlag)
                                {
                                     <MudNumericField @bind-Value="PasswordPolicy.TimeLimit" Label="Minimum Age (Minutes)" Variant="Variant.Outlined" Min="0" Max="1440" Class="glass-input" />
                                }
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                </MudGrid>
                <div class="d-flex justify-end mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SavePasswordPolicy" StartIcon="@Icons.Material.Filled.Save">Save Changes</MudButton>
                </div>
            </MudForm>
        </MudTabPanel>

        <MudTabPanel Text="Locking Policy" Icon="@Icons.Material.Filled.LockClock">
            <MudForm @ref="lockingForm" @bind-IsValid="@lockingSuccess">
                 <MudGrid>
                    <MudItem xs="12" md="6">
                         <MudCard Elevation="0" Outlined="false" Class="glass-panel">
                            <MudCardContent>
                                <MudText Typo="Typo.body2" Class="mb-4">Configure automatic account locking to prevent brute-force attacks.</MudText>
                                <MudNumericField @bind-Value="LockingPolicy.MaxAttempts" Label="Max Failed Attempts" HelperText="Before account is locked" Variant="Variant.Outlined" Min="3" Max="10" Class="glass-input" />
                                <MudNumericField @bind-Value="LockingPolicy.LockTimeMinutes" Label="Lockout Duration (Minutes)" HelperText="How long the account remains locked" Variant="Variant.Outlined" Min="5" Max="1440" Class="mt-4 glass-input" />
                            </MudCardContent>
                         </MudCard>
                    </MudItem>
                 </MudGrid>
                 <div class="d-flex justify-end mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveLockingPolicy" StartIcon="@Icons.Material.Filled.Save">Save Locking Policy</MudButton>
                 </div>
            </MudForm>
        </MudTabPanel>
    </MudTabs>
</MudContainer>
